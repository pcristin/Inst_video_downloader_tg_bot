# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
# Telegram user ID that receives owner-only alerts and can use owner commands.
BOT_OWNER_USER_ID=
# Optional: send a one-time migration notice to historical users, e.g. igclipbot.
BOT_MIGRATION_TARGET_USERNAME=
# Optional: run this token as a redirect-only legacy bot during migration.
BOT_LEGACY_REDIRECT_MODE=false

# Account health automation
# Account is removed from usable rotation after this many sequential auth/download failures.
ACCOUNT_FAILURE_THRESHOLD=2
# Notify BOT_OWNER_USER_ID when usable Instagram accounts drop below this number.
ACCOUNT_LOW_WATERMARK=3
# Minimum seconds between low-account-pool DM alerts.
ACCOUNT_ALERT_COOLDOWN_SECONDS=3600

# Instagram Credentials
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Two-Factor Authentication (optional)
# Generate this by running: docker-compose run --rm instagram-video-bot python -m src.instagram_video_bot.setup_2fa
TOTP_SECRET=

# Fast Instagram extraction (default primary path)
IG_FAST_METHOD_ENABLED=true
IG_FAST_TIMEOUT_CONNECT=10
IG_FAST_TIMEOUT_READ=45
IG_AUTH_COOKIES_FILE=
IG_AUTH_MAX_CONTEXTS_PER_ATTEMPT=2
IG_AUTH_CONTEXT_COOLDOWN_SECONDS=900

COOKIES_FILE=cookies/instagram_cookies.txt

# Proxy Configuration (optional)
# PROXY_HOST=proxy.example.com
# PROXY_PORT=8080
# PROXY_USERNAME=proxy_user
# PROXY_PASSWORD=proxy_pass

# Development Mode (optional)
# DEV_MODE=false

# Logging Level (optional)
# LOG_LEVEL=INFO

# Paid true inline mode
INLINE_MODE_ENABLED=true
INLINE_SUBSCRIPTION_REQUIRED=true
INLINE_SUBSCRIPTION_STARS=1
INLINE_SUBSCRIPTION_PERIOD_SECONDS=2592000
INLINE_ONE_TIME_ENABLED=false
INLINE_ONE_TIME_STARS=1
INLINE_SESSION_TTL_SECONDS=900
INLINE_ONE_TIME_CLAIM_RECOVERY_SECONDS=21600
INLINE_STORAGE_CHAT_ID=-1001234567890
